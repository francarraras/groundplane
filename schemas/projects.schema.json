{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "groundplane/projects.schema.json",
  "title": "Projects state file",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "projects"],
  "properties": {
    "schema_version": { "type": "string" },
    "updated_at": { "type": "string" },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title", "status", "source_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^PROJ-" },
          "title": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 },
          "health": { "type": "string" },
          "source_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^SRC-" }
          }
        }
      }
    }
  }
}
