{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "groundplane/review-queue.schema.json",
  "title": "Review queue file",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "reviews"],
  "properties": {
    "schema_version": { "type": "string" },
    "updated_at": { "type": "string" },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "type", "status", "risk", "target_file", "source_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^[A-Z][A-Z0-9]*-" },
          "type": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
          "risk": { "type": "string", "enum": ["low", "medium", "high"] },
          "target_file": { "type": "string", "minLength": 1 },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^SRC-" }
          }
        }
      }
    }
  }
}
