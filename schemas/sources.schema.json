{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "groundplane/sources.schema.json",
  "title": "Source catalog file",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "sources"],
  "properties": {
    "schema_version": { "type": "string" },
    "updated_at": { "type": "string" },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "type", "title", "path", "trust_level", "sensitivity", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^SRC-" },
          "type": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "pattern": "^sources/" },
          "trust_level": { "type": "string", "minLength": 1 },
          "sensitivity": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
