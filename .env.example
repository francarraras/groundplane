# Operator CLI (packages/operator) configuration. Copy to .env and fill in.
# The browser app reads NONE of this — it stays read-only and offline.

# Default provider for `atlas ask`: mock | ollama | anthropic
ATLAS_PROVIDER=mock

# Ollama (local, no API key) — the offline demo path.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Anthropic (hosted) — only needed when ATLAS_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
